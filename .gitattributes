# Normalize line endings across OSes: store LF in the repo, check out native.
* text=auto eol=lf

# Explicitly text
*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
.env.example text eol=lf
