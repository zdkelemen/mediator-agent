# --- LLM provider (the mediator is vendor-independent) ---
# Which backend to use: anthropic (default) or openai. Overrides config.yaml.
MEDIATOR_PROVIDER=anthropic

# Anthropic / Claude — https://console.anthropic.com  (provider: anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI or any OpenAI-compatible endpoint (provider: openai)
OPENAI_API_KEY=sk-...
# Point at a non-OpenAI endpoint to use Azure OpenAI / Ollama / LM Studio / OpenRouter / vLLM:
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- Slack (only needed for the Slack adapter) ---
# Bot token (xoxb-): from the OAuth & Permissions page
SLACK_BOT_TOKEN=xoxb-...
# App-level token (xapp-) with the connections:write scope — for Socket Mode
SLACK_APP_TOKEN=xapp-...

# --- Microsoft Teams (only needed for the Teams adapter) ---
# From the Azure Bot resource → Configuration / "Microsoft App ID" + a client secret
MICROSOFT_APP_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_APP_PASSWORD=your-client-secret
# Optional: SingleTenant / MultiTenant / UserAssignedMSI (default: MultiTenant)
MICROSOFT_APP_TYPE=MultiTenant
# Only for SingleTenant apps
MICROSOFT_APP_TENANT_ID=
# Port the Teams web endpoint listens on (default 3978)
PORT=3978

# --- Generic webhook adapter (Azure-Bot-independent Teams / any HTTP source) ---
# Optional shared secret; if set, callers must send it as the X-Mediator-Token header.
MEDIATOR_WEBHOOK_TOKEN=
# Port for the webhook adapter (default 3979)
# PORT=3979

# Optional: custom config path
# MEDIATOR_CONFIG=config.yaml
